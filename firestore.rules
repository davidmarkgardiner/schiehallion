rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() in ['staff', 'manager', 'admin'];
    }

    function isManager() {
      return isAuthenticated() && getUserRole() in ['manager', 'admin'];
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    // Users collection - role-based access
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if isOwner(userId);
      // Staff can read guest profiles
      allow read: if isStaff() && get(/databases/$(database)/documents/users/$(userId)).data.role == 'guest';
      // Managers can read all user profiles
      allow read: if isManager();
      // Admins can manage all users
      allow read, write: if isAdmin();
    }

    // Messages collection - users can read all messages and write their own
    match /messages/{document} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Audit logs - admin only
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // All authenticated users can create audit logs
      allow update, delete: if false; // Audit logs are immutable
    }

    // Legacy guest bookings (keeping for backwards compatibility)
    match /guestBookings/{bookingId} {
      // Guests can read their own bookings (by email or userId)
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.guestEmail ||
        request.auth.uid == resource.data.guestUserId
      );
      // Staff can read all bookings
      allow read: if isStaff();
      // Guests can create bookings
      allow create: if isAuthenticated();
      // Staff can update bookings
      allow update: if isStaff();
      // Only admins can delete bookings
      allow delete: if isAdmin();
    }

    // SCHH-007: Hotel Rooms Collection
    match /rooms/{roomId} {
      // All authenticated users can read room information
      allow read: if isAuthenticated();
      // Only managers and admins can create/update/delete rooms
      allow write: if isManager();
    }

    // SCHH-008: Hotel Bookings Collection
    match /bookings/{bookingId} {
      // Guests can read their own bookings (by userId or email)
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.guestUserId ||
        request.auth.token.email == resource.data.guestInfo.email ||
        isStaff()
      );
      // All authenticated users can create bookings
      allow create: if isAuthenticated() && (
        // Ensure the booking is created by the guest or staff member
        request.auth.uid == request.resource.data.createdBy ||
        isStaff()
      );
      // Staff can update bookings
      allow update: if isStaff();
      // Only admins can delete bookings (for data integrity)
      allow delete: if isAdmin();
    }

    // SCHH-009: Daily Availability Collection
    match /dailyAvailability/{date} {
      // All authenticated users can read availability
      allow read: if isAuthenticated();
      // Only managers and staff can update availability
      allow write: if isStaff();
    }

    // Booking Analytics Collection
    match /bookingAnalytics/{date} {
      // Only managers and admins can read analytics
      allow read: if isManager();
      // Only system (admin) can write analytics
      allow write: if isAdmin();
    }
  }
}