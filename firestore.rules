rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() in ['staff', 'manager', 'admin'];
    }

    function isManager() {
      return isAuthenticated() && getUserRole() in ['manager', 'admin'];
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    // Users collection - role-based access
    match /users/{userId} {
      // Users can read and write their own profile (avoid circular get() calls)
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      // Staff can read guest profiles (check role directly from resource)
      allow read: if isAuthenticated() &&
                      request.auth.uid != null &&
                      resource.data.role == 'guest' &&
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['staff', 'manager', 'admin'];
      // Managers and admins can read all user profiles
      allow read: if isAuthenticated() &&
                     exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'admin'];
      // Admins can manage all users
      allow write: if isAuthenticated() &&
                      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Messages collection - users can read all messages and write their own
    match /messages/{document} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Audit logs - admin only
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // All authenticated users can create audit logs
      allow update, delete: if false; // Audit logs are immutable
    }

    // Legacy guest bookings (keeping for backwards compatibility)
    match /guestBookings/{bookingId} {
      // Guests can read their own bookings (by email or userId)
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.guestEmail ||
        request.auth.uid == resource.data.guestUserId
      );
      // Staff can read all bookings
      allow read: if isStaff();
      // Guests can create bookings
      allow create: if isAuthenticated();
      // Staff can update bookings
      allow update: if isStaff();
      // Only admins can delete bookings
      allow delete: if isAdmin();
    }

    // SCHH-007: Hotel Rooms Collection
    match /rooms/{roomId} {
      // Allow anyone to read room information (public information)
      allow read: if true;
      // Only staff (managers and admins) can create/update/delete rooms
      allow write: if isStaff();
    }

    // SCHH-008: Hotel Bookings Collection
    match /bookings/{bookingId} {
      // Guests can read their own bookings (by userId or email)
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.guestUserId ||
        request.auth.token.email == resource.data.guestInfo.email
      );
      // Staff can read all bookings
      allow read: if isStaff();
      // All authenticated users can create bookings for themselves
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.guestUserId;
      // Authenticated users can update their own bookings
      allow update: if isAuthenticated() && request.auth.uid == resource.data.guestUserId;
      // Staff can update any booking
      allow update: if isStaff();
      // Authenticated users can delete their own bookings
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.guestUserId;
      // Staff can delete any booking
      allow delete: if isStaff();
    }

    // SCHH-009: Daily Availability Collection
    match /dailyAvailability/{date} {
      // Allow anyone to read availability (public information)
      allow read: if true;
      // Allow authenticated users to update availability (for booking creation)
      // and staff can also manage availability manually
      allow write: if isAuthenticated();
    }

    // Booking Analytics Collection
    match /bookingAnalytics/{date} {
      // Only managers and admins can read analytics
      allow read: if isManager();
      // Only system (admin) can write analytics
      allow write: if isAdmin();
    }

    // Restaurant Waitlist Collection
    match /restaurantWaitlist/{waitlistId} {
      // All authenticated users can create waitlist entries
      allow create: if isAuthenticated();
      // Users can read their own waitlist entries
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.email ||
        request.auth.uid == resource.data.userId
      );
      // Staff can read all waitlist entries
      allow read: if isStaff();
      // Staff can update waitlist entries (notify, seat, cancel)
      allow update: if isStaff();
      // Only staff can delete waitlist entries
      allow delete: if isStaff();
    }

    // Restaurant Reservations Collection
    match /restaurantReservations/{reservationId} {
      // Users can read their own reservations
      allow read: if isAuthenticated() && (
        request.auth.token.email == resource.data.email ||
        request.auth.uid == resource.data.userId
      );
      // Staff can read all reservations
      allow read: if isStaff();
      // All authenticated users can create reservations
      allow create: if isAuthenticated();
      // Staff can update reservations
      allow update: if isStaff();
      // Only staff can delete reservations
      allow delete: if isStaff();
    }
  }
}