{
  "rules": {
    ".read": false,
    ".write": false,

    "availability": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'staff' || root.child('users').child(auth.uid).child('role').val() == 'manager' || root.child('users').child(auth.uid).child('role').val() == 'admin')",

      "$date": {
        ".validate": "$date.matches(/^\\d{4}-\\d{2}-\\d{2}$/)",

        "$roomType": {
          "available": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "booked": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "lastUpdated": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },

    "bookingLocks": {
      ".read": "auth != null",
      ".write": "auth != null",

      "$lockId": {
        ".validate": "newData.hasChildren(['userId', 'roomId', 'checkIn', 'checkOut', 'timestamp']) && newData.child('userId').val() == auth.uid",
        "userId": {
          ".validate": "newData.isString() && newData.val() == auth.uid"
        },
        "roomId": {
          ".validate": "newData.isString()"
        },
        "checkIn": {
          ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)"
        },
        "checkOut": {
          ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        }
      }
    },

    "occupancyStatus": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'staff' || root.child('users').child(auth.uid).child('role').val() == 'manager' || root.child('users').child(auth.uid).child('role').val() == 'admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() == 'staff' || root.child('users').child(auth.uid).child('role').val() == 'manager' || root.child('users').child(auth.uid).child('role').val() == 'admin')",

      "$roomId": {
        "status": {
          ".validate": "newData.isString() && (newData.val() == 'available' || newData.val() == 'occupied' || newData.val() == 'maintenance' || newData.val() == 'cleaning' || newData.val() == 'out-of-order')"
        },
        "lastUpdated": {
          ".validate": "newData.isNumber()"
        },
        "updatedBy": {
          ".validate": "newData.isString()"
        }
      }
    }
  }
}